# ==============================================================
# JBABI — Variables d'environnement
# Copier ce fichier en `.env.local` (dev) ou configurer sur Vercel.
# ==============================================================

# --- Auth.js (NextAuth v5) ---
# Génère un secret avec : openssl rand -base64 32
AUTH_SECRET=

# --- Compte patron (l'unique utilisateur autorisé) ---
ADMIN_EMAIL=patron@jbabi.ci
# Hash bcrypt — généré avec : npm run hash-password "ton_mot_de_passe"
ADMIN_PASSWORD_HASH=

# --- Google Sheets ---
# 1. Créer un projet sur https://console.cloud.google.com
# 2. Activer "Google Sheets API"
# 3. Créer un compte de service (Service Account)
# 4. Générer une clé JSON, copier email + private_key ci-dessous
# 5. Partager le Google Sheet avec l'email du compte de service (lecture)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Coller la clé privée. Conserver les "\n" pour les retours à la ligne.
# Exemple : "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=

# ID du spreadsheet (la chaîne entre /d/ et /edit dans l'URL).
# URL de référence du projet :
#   https://docs.google.com/spreadsheets/d/164KqlBoHC4E4KGI3Sox5SgB76tSg83N9fyWBhzF7YBs/edit
GOOGLE_SHEET_ID=164KqlBoHC4E4KGI3Sox5SgB76tSg83N9fyWBhzF7YBs
# Onglet de saisie. Par défaut : 'Suivi Journalier'!A1:L
# Les guillemets simples sont requis car le nom contient un espace.
GOOGLE_SHEET_RANGE='Suivi Journalier'!A1:L
